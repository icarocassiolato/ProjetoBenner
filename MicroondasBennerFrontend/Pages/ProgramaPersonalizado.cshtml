@page

<h2>Programas Personalizados</h2>

<button onclick="window.location.href='/'">Voltar</button>

<hr>

<h3>Novo Programa</h3>

<div>
    <input id="nome" placeholder="Nome" />
</div>

<div>
    <input id="tempo" type="number" placeholder="Tempo" />
</div>

<div>
    <input id="potencia" type="number" placeholder="Potência" />
</div>

<div>
    <input id="instrucoes" placeholder="Instruções" />
</div>

<div>
    <input id="simboloProgresso" maxlength="1" placeholder="Símbolo de Progresso" />
</div>

<br>

<button onclick="salvarPrograma()">Salvar</button>

<hr>

<h3>Programas Cadastrados</h3>

<table border="1" width="100%">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Tempo</th>
            <th>Potência</th>
            <th>Instruções</th>
            <th>Símbolo progresso</th>
        </tr>
    </thead>

    <tbody id="listaProgramas"></tbody>
</table>

<script>

    const token = localStorage.getItem("token");

    if(!token){
        window.location.href = "/Login";
    }

    let editandoId = null;

    async function carregarProgramas() {

        const response = await fetch("https://localhost:5001/programaspersonalizados", {
            headers: {
                "Authorization": `Bearer ${token}`
            }
        });

        const programas = await response.json();

        const tabela = document.getElementById("listaProgramas");
        tabela.innerHTML = "";

        programas.forEach(p => {

            const linha = document.createElement("tr");

            linha.innerHTML = `
                <td>${p.nome}</td>
                <td>${p.tempo}</td>
                <td>${p.potencia}</td>
                <td>${p.instrucoes}</td>
                <td>${p.simboloProgresso}</td>
                <td>
                    <button onclick="editarPrograma(${p.id},'${p.nome}',${p.tempo},${p.potencia},'${p.instrucoes}', '${p.simboloProgresso}')">Editar</button>
                    <button onclick="excluirPrograma(${p.id})">Excluir</button>
                </td>
            `;

            tabela.appendChild(linha);
        });
    }

    function editarPrograma(id, nome, tempo, potencia, instrucoes, simboloProgresso){

        editandoId = id;

        document.getElementById("nome").value = nome;
        document.getElementById("tempo").value = tempo;
        document.getElementById("potencia").value = potencia;
        document.getElementById("instrucoes").value = instrucoes;
        document.getElementById("simboloProgresso").value = simboloProgresso;
    }

    function getUserIdFromToken() {
        if (!token)
            return null;

        try {
            const payload = token.split('.')[1];
            const decoded = JSON.parse(atob(payload));
            return decoded.nameid;
        }
        catch {
            return null;
        }
    }

    async function salvarPrograma(){

        const programa = {
            nome: document.getElementById("nome").value,
            tempo: Number(document.getElementById("tempo").value),
            potencia: Number(document.getElementById("potencia").value),
            instrucoes: document.getElementById("instrucoes").value,
            simboloProgresso: document.getElementById("simboloProgresso").value,
            idusuario: getUserIdFromToken()
        };

        let response;

        if(editandoId){
            programa.id = editandoId;

            response = await fetch(`https://localhost:5001/programaspersonalizados/${editandoId}`,{
                method:"PUT",
                headers:{
                    "Authorization":`Bearer ${token}`,
                    "Content-Type":"application/json"
                },
                body: JSON.stringify(programa)
            });

            editandoId = null;
        }else{
            response = await fetch("https://localhost:5001/programaspersonalizados",{
                method:"POST",
                headers:{
                    "Authorization":`Bearer ${token}`,
                    "Content-Type":"application/json"
                },
                body: JSON.stringify(programa)
            });
        }

        if(!response.ok) {
            console.log("errooooooooooooooo");
            const erro = await response.text();
            console.log(erro);
            alert(erro);
            console.log(erro);
            console.log("errooooooooooooooo2222");
            return;
        }

        limparCampos();
        carregarProgramas();
    }

    async function excluirPrograma(id){

        if(!confirm("Excluir programa?"))
            return;

        await fetch(`https://localhost:5001/programaspersonalizados/${id}`,{
            method:"DELETE",
            headers:{
                "Authorization":`Bearer ${token}`
            }
        });

        carregarProgramas();
    }

    function limparCampos(){

        document.getElementById("nome").value="";
        document.getElementById("tempo").value="";
        document.getElementById("potencia").value="";
        document.getElementById("instrucoes").value="";
        document.getElementById("simboloProgresso").value="";
    }

    async function inicializar(){
        await carregarProgramas();
    }

    window.onload = inicializar;

</script>