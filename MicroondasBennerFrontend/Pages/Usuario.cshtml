@page

<h2>Cadastro de Usuários</h2>

<button onclick="window.location.href='/'">Voltar</button>

<hr>

<h3>Novo Usuário</h3>

<div>
    <input id="nome" placeholder="Nome" />
</div>

<div>
    <input id="senha" type="password" placeholder="Senha" />
</div>

<br>

<button onclick="salvarUsuario()">Salvar</button>

<hr>

<h3>Usuários Cadastrados</h3>

<table border="1" width="100%">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Senha</th>
            <th>Ações</th>
        </tr>
    </thead>

    <tbody id="listaUsuarios"></tbody>
</table>

<script>

    let token = null;
    let editandoId = null;

    async function login(){

        const response = await fetch("https://localhost:5001/Login",{
            method:"POST",
            headers:{
                "Content-Type":"application/json"
            },
            body: JSON.stringify({
                Email:"teste@benner.com",
                Password:"123"
            })
        });

        const data = await response.json();
        token = data.token;
    }

    async function carregarUsuarios(){

        const response = await fetch("https://localhost:5001/usuario",{
            headers:{
                "Authorization":`Bearer ${token}`
            }
        });

        const usuarios = await response.json();

        const tabela = document.getElementById("listaUsuarios");
        tabela.innerHTML = "";

        usuarios.forEach(u=>{

            const linha = document.createElement("tr");

            linha.innerHTML = `
                <td>${u.nome}</td>
                <td>******</td>
                <td>
                    <button onclick="editarUsuario(${u.id},'${u.nome}')">Editar</button>
                    <button onclick="excluirUsuario(${u.id})">Excluir</button>
                </td>
            `;

            tabela.appendChild(linha);
        });
    }

    function editarUsuario(id,nome){

        editandoId = id;

        document.getElementById("nome").value = nome;
        document.getElementById("senha").value = "";
    }

    async function salvarUsuario(){
        const usuario = {
            nome: document.getElementById("nome").value,
            senha: document.getElementById("senha").value
        };

        if(editandoId){

            usuario.id = editandoId;

            await fetch(`https://localhost:5001/usuario/${editandoId}`,{
                method:"PUT",
                headers:{
                    "Authorization":`Bearer ${token}`,
                    "Content-Type":"application/json"
                },
                body: JSON.stringify(usuario)
            });

            editandoId = null;

        }else{

            await fetch("https://localhost:5001/usuario",{
                method:"POST",
                headers:{
                    "Authorization":`Bearer ${token}`,
                    "Content-Type":"application/json"
                },
                body: JSON.stringify(usuario)
            });

        }

        limparCampos();
        carregarUsuarios();
    }

    async function excluirUsuario(id){

        if(!confirm("Excluir usuário?"))
            return;

        await fetch(`https://localhost:5001/usuario/${id}`,{
            method:"DELETE",
            headers:{
                "Authorization":`Bearer ${token}`
            }
        });

        carregarUsuarios();
    }

    function limparCampos(){

        document.getElementById("nome").value="";
        document.getElementById("senha").value="";
    }

    async function inicializar(){

        await login();
        await carregarUsuarios();
    }

    window.onload = inicializar;

</script>